{% assign plan = shop.metafields.custom["company-logo"] %}
{% assign is_premium = false %}
{% if plan == 'Basic' or plan == 'premium' %}
  {% assign is_premium = true %}
{% endif %}

{% if is_premium or template.name == 'index' %}

<div class="mxtt-logo-marquee" style="background: {{ block.settings.background_color }};">
  
  {% if block.settings.heading != blank %}
    <h2 class="mxtt-logo-heading">{{ block.settings.heading }}</h2>
  {% endif %}

  <div class="mxtt-marquee-track">
    {% for repeat in (1..2) %}
      {% for i in (1..8) %}
        {% assign image_key = 'image_' | append: i %}
        {% assign link_key = 'link_' | append: i %}
        {% assign logo_image = block.settings[image_key] %}
        {% assign logo_link = block.settings[link_key] %}

        {% if logo_image != blank %}
          <div class="mxtt-logo-item">
            {% if logo_link != blank %}
              <a href="{{ logo_link }}" target="_blank" rel="noopener">
            {% endif %}

            <img
              src="{{ logo_image | image_url: width: 400 }}"
              class="mxtt-logo-img"
              alt="logo" height="" width=""
            >

            {% if logo_link != blank %}
              </a>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    {% endfor %}
  </div>
</div>

<style>
.mxtt-logo-marquee {
  width: 100%;
  overflow: hidden;
  padding: 28px 0;
}

.mxtt-logo-heading {
  text-align: center;
  margin-bottom: 30px;
  margin-top:0px;
    font-size: {{ block.settings.heading_size_desktop }}px;
  font-weight: 700;
}

.mxtt-marquee-track {
  display: flex;
  gap: 40px;
  width: max-content;
  animation: mxtt-marquee {{ block.settings.speed }}s linear infinite;
  align-items: center;
}

.mxtt-logo-item {
  min-width: 140px;
  display: flex;
  justify-content: center;
  align-items: center;
}

.mxtt-logo-img {
  width: {{ block.settings.logo_width }}px;
  height: {{ block.settings.logo_height }}px;
  object-fit: contain;

}

@keyframes mxtt-marquee {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

@media(max-width:768px){
  .mxtt-marquee-track{
    gap:15px;
  }
  .mxtt-logo-heading {
      font-size: {{ block.settings.heading_size_mobile }}px;

}

}
</style>

{% endif %}

{% schema %}
{
  "name": "LogoFlow Marquee",
  "target": "section",
  "settings": [
    {
  "type": "header",
  "content": "Free: Homepage only | Premium: All pages"
},
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
     {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Heading size (mobile)",
      "min": 14,
      "max": 40,
      "step": 1,
      "default": 22
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "label": "Heading size (desktop)",
      "min": 16,
      "max": 60,
      "step": 1,
      "default": 28
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo width",
      "min": 50,
      "max": 300,
      "step": 10,
      "default": 140
    },
    {
      "type": "range",
      "id": "logo_height",
      "label": "Logo height",
      "min": 20,
      "max": 150,
      "step": 5,
      "default": 60
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Marquee speed (seconds)",
      "min": 5,
      "max": 40,
      "step": 1,
      "default": 20
    },

    { "type": "header", "content": "Logos" },

    { "type": "image_picker", "id": "image_1", "label": "Logo 1" },
    { "type": "url", "id": "link_1", "label": "Logo 1 link" },

    { "type": "image_picker", "id": "image_2", "label": "Logo 2" },
    { "type": "url", "id": "link_2", "label": "Logo 2 link" },

    { "type": "image_picker", "id": "image_3", "label": "Logo 3" },
    { "type": "url", "id": "link_3", "label": "Logo 3 link" },

    { "type": "image_picker", "id": "image_4", "label": "Logo 4" },
    { "type": "url", "id": "link_4", "label": "Logo 4 link" },

    { "type": "image_picker", "id": "image_5", "label": "Logo 5" },
    { "type": "url", "id": "link_5", "label": "Logo 5 link" },

    { "type": "image_picker", "id": "image_6", "label": "Logo 6" },
    { "type": "url", "id": "link_6", "label": "Logo 6 link" },

    { "type": "image_picker", "id": "image_7", "label": "Logo 7" },
    { "type": "url", "id": "link_7", "label": "Logo 7 link" },

    { "type": "image_picker", "id": "image_8", "label": "Logo 8" },
    { "type": "url", "id": "link_8", "label": "Logo 8 link" }
  ]
}
{% endschema %}
